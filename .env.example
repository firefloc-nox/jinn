# ═══════════════════════════════════════════════════════════════════════════════
# Jinn×Hermes Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All variables have sensible defaults — only set what you need to change.

# ─────────────────────────────────────────────────────────────────────────────────
# Core Settings
# ─────────────────────────────────────────────────────────────────────────────────

# Gateway port (HTTP + WebSocket)
JINN_PORT=7777

# Data directory for sessions, logs, state
# JINN_DATA_DIR=~/.jinn

# Log level: debug, info, warn, error
# LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────────
# Hermes Integration
# ─────────────────────────────────────────────────────────────────────────────────

# Hermes installation directory
# HERMES_HOME=~/.hermes

# Hermes WebAPI endpoint (if running Hermes in server mode)
# HERMES_WEBAPI_URL=http://127.0.0.1:8642

# Default Hermes profile to use
# HERMES_PROFILE=default

# ─────────────────────────────────────────────────────────────────────────────────
# Honcho (Optional — vectorial memory)
# ─────────────────────────────────────────────────────────────────────────────────

# Honcho server URL
# HONCHO_URL=http://127.0.0.1:8000

# Peer name (user identifier in Honcho)
# HONCHO_PEER_NAME=default

# App name (workspace identifier)
# HONCHO_APP_NAME=hermes

# ─────────────────────────────────────────────────────────────────────────────────
# AI Provider Keys (if not using Hermes auth)
# ─────────────────────────────────────────────────────────────────────────────────

# Anthropic API key (for direct Claude access)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (for Codex)
# OPENAI_API_KEY=sk-...

# Google AI API key (for Gemini)
# GOOGLE_AI_API_KEY=...

# OpenRouter API key (for fallback routing)
# OPENROUTER_API_KEY=sk-or-...

# ─────────────────────────────────────────────────────────────────────────────────
# Connectors (Optional)
# ─────────────────────────────────────────────────────────────────────────────────

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...

# Discord
# DISCORD_BOT_TOKEN=...
# DISCORD_APPLICATION_ID=...

# Telegram
# TELEGRAM_BOT_TOKEN=...

# ─────────────────────────────────────────────────────────────────────────────────
# Database (Optional — for persistent state)
# ─────────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection (used by Honcho)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jinn

# ─────────────────────────────────────────────────────────────────────────────────
# Development
# ─────────────────────────────────────────────────────────────────────────────────

# Enable debug mode (verbose logging, dev endpoints)
# DEBUG=true

# Disable telemetry
# DO_NOT_TRACK=1
